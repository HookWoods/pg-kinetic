{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pg-kinetic regression manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "case"],
  "properties": {
    "version": { "const": 1 },
    "case": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "category",
          "platform",
          "timeout_seconds",
          "services",
          "command"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "category": {
            "enum": ["smoke", "protocol", "docs", "benchmark", "compatibility"]
          },
          "platform": { "enum": ["linux", "windows", "all"] },
          "timeout_seconds": { "type": "integer", "minimum": 1 },
          "services": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": true
          },
          "command": { "type": "string", "minLength": 1 },
          "success_marker": { "type": "string", "minLength": 1 },
          "artifact_policy": { "enum": ["none", "summary", "large"] },
          "artifact_path": {
            "type": "string",
            "pattern": "^target/(?!private(?:/|$))(?!drafts?(?:/|$))(?!planning(?:/|$))(?!generated-output(?:/|$))(?!.*(?:/(?:private|drafts?|planning|generated-output)(?:/|$))).+"
          },
          "compatibility": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "suite_id",
              "language",
              "library",
              "library_version",
              "target",
              "command",
              "timeout_seconds",
              "required_services",
              "artifact_policy",
              "artifact_path",
              "smoke",
              "category",
              "required"
            ],
            "properties": {
              "suite_id": {
                "type": "string",
                "pattern": "^[a-z0-9-]{1,96}$"
              },
              "language": {
                "enum": [
                  "rust",
                  "go",
                  "java",
                  "javascript",
                  "python",
                  "dotnet",
                  "c",
                  "cpp"
                ]
              },
              "library": { "type": "string", "minLength": 1 },
              "library_version": { "type": "string", "minLength": 1 },
              "target": { "enum": ["direct-postgres", "pg-kinetic"] },
              "command": { "type": "string", "minLength": 1 },
              "timeout_seconds": { "type": "integer", "minimum": 1 },
              "required_services": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": true
              },
              "artifact_policy": { "enum": ["none", "summary", "large"] },
              "artifact_path": {
                "type": "string",
                "pattern": "^target/compat/.+"
              },
              "smoke": { "type": "boolean" },
              "category": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" },
              "skip_reason": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
